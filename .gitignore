# Env (.env.example is the tracked template; .env / .env.* / .envrc hold real secrets)
.env
.env.*
!.env.example
.envrc
# Secret TOML configs — mirrors .claude/hooks/block-secrets.sh so git won't commit
# what the hook won't let Claude edit. (.streamlit/config.toml themes are tracked; secrets are not.)
secrets.toml
.secrets.toml
.venv/

# Caches
__pycache__/
.pytest_cache/
.ruff_cache/

# App exports (the Download buttons produce these; never part of the repo)
transcripts.txt
subtitles.srt

# OS
.DS_Store

# Claude Code (.claude/settings.json + hooks/ are tracked; personal overrides are not)
.claude/settings.local.json
