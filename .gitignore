# Env (.env.example is the tracked template; .env / .env.* / .envrc hold real secrets)
.env
.env.*
!.env.example
.envrc
# Secret TOML configs the block-secrets hook guards — keep them out of git too.
# (.streamlit/config.toml themes are tracked; secrets are not.)
secrets.toml
.secrets.toml

# Caches
__pycache__/
.pytest_cache/
.ruff_cache/
.venv/

# App exports (the Download buttons produce these; never part of the repo)
transcripts.txt
subtitles.srt

# OS
.DS_Store

# Claude Code (.claude/settings.json + hooks/ are tracked; personal overrides are not)
.claude/settings.local.json

# Release automation is fully tracked, not ignored: release-please-config.json,
# .release-please-manifest.json, and the release-please-generated CHANGELOG.md
# carry no secrets and drive the GitHub release flow, so they stay in git.
