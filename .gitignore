# Env (.env.example is the tracked template; .env holds real secrets)
.env
!.env.example
# Streamlit secrets (.streamlit/config.toml light/dark themes are tracked; secrets.toml is not)
.streamlit/secrets.toml
.venv/

# Caches
__pycache__/
.pytest_cache/
.ruff_cache/

# App exports (the Download buttons produce these; never part of the repo)
transcripts.txt
subtitles.srt

# OS
.DS_Store

# Claude Code (.claude/settings.json + hooks/ are tracked; personal overrides are not)
.claude/settings.local.json
