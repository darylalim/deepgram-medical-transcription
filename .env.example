# Copy to .env (gitignored) and fill in. Both front-ends read this file via python-dotenv.

# Required — your Deepgram API key (server-side only; the API never accepts it per-request).
DEEPGRAM_API_KEY=

# Required by the FastAPI service — comma-separated bearer tokens (one per consumer, each
# revocable independently). The Streamlit UI does not use these. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_TOKENS=

# --- Optional API tuning (defaults shown) ---
# Bind host the service is started on. A non-loopback value REQUIRES API_AUTH_TOKENS or the
# server refuses to start, and disables the /docs + /openapi.json routes.
# API_HOST=127.0.0.1
# Whole-request body cap (bytes). Default = 2 GiB + 16 MiB framing headroom (one maximal
# file per request; use URL batches for bulk audio).
# MAX_REQUEST_BYTES=2164260864
# Upstream per-call timeout (seconds); mainly reclaims the concurrency gate from hung calls.
# DEEPGRAM_TIMEOUT_SECONDS=600
# Max concurrent upstream Deepgram calls across ALL in-flight requests (the spend governor).
# GLOBAL_MAX_CONCURRENCY=5
